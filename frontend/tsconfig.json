{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/app-chat.tsx",
    "components/app-chat-input.tsx",
    "components/app-header.tsx",
    "components/chat-activity.tsx",
    "components/chat-shell.tsx",
    "components/theme-toggle.tsx",
    "components/ai-elements/chain-of-thought.tsx",
    "components/ai-elements/conversation.tsx",
    "components/ai-elements/external-link-modal.tsx",
    "components/ai-elements/message.tsx",
    "components/ui/**/*.tsx",
    "lib/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
